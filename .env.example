# ─── 필수 ────────────────────────────────────────────────────────
# Supabase 프로젝트 → Project Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your_anon_or_publishable_key...

# ─── 사용자 초대 기능에 필요 (관리자가 새 사용자를 메일로 초대) ───
# 이 키는 RLS를 우회하는 슈퍼유저 키입니다. 절대 클라이언트 코드·GitHub에 노출 금지.
# Vercel 환경변수에만 등록하세요 (Project Settings → Environment Variables → Production만 체크).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role_key...

# ─── 신규 가입 시 admin 이메일 알림에 필요 (선택) ────────────────
# https://resend.com 가입 → API Keys 발급 → 여기에 붙여넣기
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 알림을 받을 admin 이메일 (쉼표로 여러 명 가능)
ADMIN_NOTIFY_EMAILS=kwon.ohkyung@gmail.com
# 발신 도메인 (Resend에 검증된 도메인). 미설정 시 onboarding@resend.dev 사용.
RESEND_FROM_EMAIL=Woodbank <noreply@yourdomain.com>
# Supabase Database Webhook 보안용 임의 비밀 문자열 (32자 이상 권장)
WEBHOOK_SECRET=replace_with_random_32_chars_or_longer

# ─── Vercel Cron (Supabase Free 일시중지 방지) ───────────────────
# vercel.json 의 cron 이 매일 /api/cron/keepalive 를 호출할 때
# Authorization: Bearer <CRON_SECRET> 헤더를 검증하는 비밀 문자열 (32자 이상).
# 생성: `openssl rand -hex 32`. Vercel 환경변수에만 등록 (Production·Preview 체크).
# 미설정 시 라우트는 500 으로 응답하며 Supabase 호출 안 함 — 안전 default.
CRON_SECRET=replace_with_random_32_chars_or_longer

# ─── 도메인 (옵션) ────────────────────────────────────────────────
# 이메일 redirect 의 기준이 되는 도메인. Vercel 운영 도메인.
NEXT_PUBLIC_SITE_URL=https://woodbank-app.vercel.app

# ─── 주소 자동 채우기 (옵션) ─────────────────────────────────────
# VWorld(국토교통부 공간정보) API 키. 발급: https://www.vworld.kr → 인증/API 키
# 키 발급 시 운영 도메인을 등록해야 합니다.
# 미설정 시 OpenStreetMap Nominatim 으로 자동 fallback(정확도는 다소 낮음).
VWORLD_API_KEY=
